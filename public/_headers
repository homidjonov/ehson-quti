# index.html hech qachon keshlanmasin — yangi build chiqsa darhol yangilansin
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# SPA fallback uchun ham
/*
  Cache-Control: no-cache, no-store, must-revalidate

# Assets (JS/CSS) hash bilan nomlanadi, uzoq keshlanishi mumkin
/assets/*
  Cache-Control: public, max-age=31536000, immutable
